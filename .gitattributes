# Keep GitHub language statistics representative of the OneMove source code.
# Generated reports and vendored artifacts are excluded from linguist stats.
playwright-report/** linguist-generated=true
test-results/** linguist-generated=true
coverage/** linguist-generated=true
docs/**/*.html linguist-generated=true
*.tsbuildinfo linguist-generated=true
.next/** linguist-generated=true

# Force Jupyter Notebooks to be classified as Python instead of "Other"
*.ipynb linguist-language=Python
